{
  "version": 2,
  "buildCommand": "cd source/frontend && npm ci && npm run build",
  "outputDirectory": "source/frontend/dist",
  "installCommand": "cd source/frontend && npm ci",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "http://127.0.0.1:8000/api/:path*" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
